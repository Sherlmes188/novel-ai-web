NODE_ENV=development
APP_URL=http://localhost:3000

DATABASE_URL=postgresql://novel_user:change_me@127.0.0.1:5432/novel_ai

SESSION_SECRET=change_to_a_long_random_string
# Optional bootstrap account. The app now authenticates against the User table;
# use `npm run create-user -- username password` to add more accounts.
LOGIN_USERNAME=admin
LOGIN_PASSWORD_HASH=replace_with_bcrypt_hash

DEEPSEEK_API_KEY=replace_with_your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_OUTPUT_TOKENS=6000
DEEPSEEK_TIMEOUT_MS=120000

AI_DEFAULT_TEMPERATURE=0.8
AI_PLANNING_TEMPERATURE=0.7
AI_REVIEW_TEMPERATURE=0.3

# Fanqie publisher. Leave FANQIE_CONFIRM_SUBMIT empty until selectors have
# been verified; set it to "yes" only when you are ready for automatic submit.
FANQIE_WORKSPACE_URL=
FANQIE_PUBLISH_URL=
FANQIE_STORAGE_STATE=.auth/fanqie.json
FANQIE_CHROME_EXECUTABLE=
FANQIE_SCREENSHOT_DIR=logs/fanqie-screenshots
FANQIE_NEW_CHAPTER_SELECTOR=
FANQIE_CHAPTER_NUMBER_SELECTOR=
FANQIE_TITLE_SELECTOR=
FANQIE_CONTENT_SELECTOR=
FANQIE_SCHEDULE_SELECTOR=
FANQIE_SUBMIT_SELECTOR=
FANQIE_LOGIN_CHECK_SELECTOR=
FANQIE_CAPTCHA_SELECTOR=
FANQIE_CONFIRM_SUBMIT=
